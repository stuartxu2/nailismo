// Nailismo iOS — example secrets. Copy to `Secrets.xcconfig` (gitignored) and
// fill the values from apps/app/.env. The Storefront token is the PUBLIC,
// client-safe token — never put the Admin token here.
//
// NOTE: xcconfig treats `//` as a comment ANYWHERE on a line, so a full
// `https://…` URL cannot be stored directly. Store the host only; Config.swift
// prepends the scheme. (Wiring lands in Pass 2.)
//
// Key mapping (apps/app/.env  ->  here):
//   EXPO_PUBLIC_SHOPIFY_STORE_DOMAIN  -> SHOPIFY_STORE_DOMAIN
//   EXPO_PUBLIC_SHOPIFY_PUBLIC_TOKEN  -> SHOPIFY_STOREFRONT_TOKEN  (public, client-safe)
//   EXPO_PUBLIC_SHOPIFY_API_VERSION   -> SHOPIFY_API_VERSION
//   EXPO_PUBLIC_SCAN_API_URL          -> SCAN_API_HOST  (host only, no scheme)

SHOPIFY_STORE_DOMAIN =
SHOPIFY_STOREFRONT_TOKEN =
SHOPIFY_API_VERSION = 2026-01
SCAN_API_HOST = nailismo.com
