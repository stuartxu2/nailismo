<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Nailismo</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>AccentColor</string>
	</dict>
	<key>UIApplicationSupportsIndefiniteFrameTime</key>
	<false/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIAppFonts</key>
	<array>
		<string>Fredoka-Variable.ttf</string>
		<string>Nunito-Variable.ttf</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Nailismo uses your camera to measure your nail size from a photo of your hand beside a bank card.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Nailismo can measure your nail size from a photo you choose from your library.</string>
	<key>ShopifyStoreDomain</key>
	<string>$(SHOPIFY_STORE_DOMAIN)</string>
	<key>ShopifyStorefrontToken</key>
	<string>$(SHOPIFY_STOREFRONT_TOKEN)</string>
	<key>ShopifyApiVersion</key>
	<string>$(SHOPIFY_API_VERSION)</string>
	<key>ScanApiHost</key>
	<string>$(SCAN_API_HOST)</string>
</dict>
</plist>
